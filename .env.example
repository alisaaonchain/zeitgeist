BIRDEYE_API_KEY=your_server_side_birdeye_key

# Optional comma-separated frontend origins allowed to use the Vercel REST proxy.
# Same-origin Vercel requests and VERCEL_URL are allowed automatically.
# ALLOWED_ORIGIN=https://your-app.vercel.app,https://your-custom-domain.com

# Optional. Production Vercel deployments use same-origin /api/birdeye by default.
# Set this only when the Vite frontend is served from a different origin than the API.
# VITE_BIRDEYE_REST_PROXY_URL=http://127.0.0.1:3000
